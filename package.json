{
  "name": "medikit",
  "main": "expo-router/entry",
  "version": "1.2.6",
  "scripts": {
    "start": "expo start",
    "android": "npm run pba && expo run:android --device",
    "ios": "npm run pbi && expo run:ios --device",
    "web": "expo start --web",
    "pbi": "expo prebuild --platform ios",
    "pba": "expo prebuild --platform android",
    "prebuild": "expo prebuild",
    "lint": "expo lint",
    "build": "eas build",
    "build:apk": "eas build -p android --profile apk",
    "build:apk:local": "expo prebuild --platform android --clean && node scripts/build-apk.js",
    "generate-keystore": "node scripts/generate-keystore.js",
    "jobs": "adb shell dumpsys jobscheduler | grep -A 40 -m 1 -E \"JOB #.* com.rkanik.medikit\"",
    "job": "adb shell cmd jobscheduler run -f com.rkanik.medikit",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@dariyd/react-native-document-scanner": "^2.0.17",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
